{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/pre-commit-tests.sh",
        "matcher": "git\\s+commit\\b",
        "timeout": 30
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/restart-dev-on-agent-stop.sh",
        "timeout": 120
      }
    ]
  }
}
